    <string name="audio_volume">Volume</string>
    <string name="audio_mute">Mute</string>
    <string name="audio_time_stretch">Time Stretch</string>
    <string name="audio_time_stretch_help">Keeps audio pitch stable when emulation speed varies. Off = a bit less CPU, but pitch/clock can drift.</string>
    <string name="audio_buffer">Audio Buffer</string>
    <string name="audio_buffer_help">Bigger buffer = fewer crackles/dropouts but more latency. Raise this if audio stutters on low-end devices.</string>
    <string name="audio_output_latency">Output Latency</string>
    <string name="audio_output_latency_help">Target output latency. Lower is more responsive; higher is safer against dropouts.</string>
    <string name="audio_ff_volume">Fast-Forward Volume</string>
    <string name="audio_ff_volume_help">Output volume while fast-forwarding.</string>

    <!-- ============================================================
         settings/FixesTab.kt
         ============================================================ -->
    <string name="fixes_section_hardware">Hardware Fixes</string>
    <string name="fixes_section_upscaling">Upscaling Fixes</string>
    <string name="fixes_section_display">Display Fixes</string>
    <string name="fixes_display_help">PCRTC / presentation fixes for the displayed image. Anti-Blur is on by default; the rest are off unless a game needs them.</string>
    <string name="fixes_anti_blur">Anti-Blur</string>
    <string name="fixes_anti_blur_help">Reduces the blur PCSX2 adds to mimic the PS2\'s blend. On by default.</string>
    <string name="fixes_screen_offsets">Screen Offsets</string>
    <string name="fixes_screen_offsets_help">Applies the PCRTC screen offsets (centres the image like real hardware).</string>
    <string name="fixes_show_overscan">Show Overscan</string>
    <string name="fixes_show_overscan_help">Shows the overscan border area some games render into.</string>
    <string name="fixes_disable_interlace_offset">Disable Interlace Offset</string>
    <string name="fixes_disable_interlace_offset_help">Removes the interlace field offset; can stop shimmer but may add combing.</string>
    <string name="fixes_sync_to_host_refresh">Sync To Host Refresh</string>
    <string name="fixes_sync_to_host_refresh_help">Paces emulation to your screen\'s refresh rate for smoother scrolling.</string>
    <string name="fixes_disable_framebuffer_fetch">Disable Framebuffer Fetch</string>
    <string name="fixes_disable_framebuffer_fetch_help">Disables the framebuffer-fetch blending path. Diagnostic / compatibility.</string>
    <string name="fixes_override_texture_barriers">Override Texture Barriers</string>
    <string name="fixes_override_texture_barriers_help">Forces the renderer\'s texture-barrier support on/off. Auto is recommended.</string>
    <string name="fixes_hw_accurate_alpha_test">HW Accurate Alpha Test</string>
    <string name="fixes_hw_accurate_alpha_test_help">More accurate hardware alpha testing. Fixes some transparency artifacts; small speed cost.</string>
    <string name="fixes_disable_vertex_shader_expand">Disable Vertex Shader Expand</string>
    <string name="fixes_disable_vertex_shader_expand_help">Forces CPU vertex expansion instead of the vertex shader. Renderer-init — restart the game to apply.</string>
    <string name="fixes_use_blit_swap_chain">Use Blit Swap Chain</string>
    <string name="fixes_use_blit_swap_chain_help">Uses a blit present model instead of flip. Renderer-init — restart the game to apply.</string>
    <string name="fixes_disable_shader_cache">Disable Shader Cache</string>
    <string name="fixes_disable_shader_cache_help">Don\'t cache compiled shaders to disk (recompiles each launch). Renderer-init — restart the game to apply.</string>
    <string name="fixes_integer_scaling">Integer Scaling</string>
    <string name="fixes_integer_scaling_help">Scales the image by whole-number factors for crisp, even pixels.</string>
    <string name="fixes_dithering">Dithering</string>
    <string name="fixes_dithering_help">Reduces colour banding. Unscaled matches the PS2 most closely.</string>
    <string name="fixes_vsync_queue_size">Vsync Queue Size</string>
    <string name="fixes_vsync_queue_size_help">Frames the GS thread may queue ahead. Higher can smooth pacing; adds latency.</string>
    <string name="fixes_upscaling_help">Only active when upscaling above Native. They reduce alignment/seam/colour artifacts at the cost of speed.</string>
    <string name="fixes_half_pixel_offset">Half-Pixel Offset</string>
    <string name="fixes_half_pixel_offset_help">Fixes shifted or blurry geometry/textures in some upscaled games.</string>
    <string name="fixes_round_sprite">Round Sprite</string>
    <string name="fixes_round_sprite_help">Rounds sprite coordinates to reduce seams or lines in 2D elements.</string>
    <string name="fixes_bilinear_filter">Bilinear Filter</string>
    <string name="fixes_bilinear_filter_help">Changes bilinear filtering behavior for upscaled textures.</string>
    <string name="fixes_vertical_stretch">Vertical Stretch</string>
    <string name="fixes_vertical_stretch_help">Fixes vertical lines/gaps in some 2D games when upscaling.</string>
    <string name="fixes_merge_sprites">Merge Sprites</string>
    <string name="fixes_merge_sprites_help">Merges adjacent post-process sprites to remove seams.</string>
    <string name="fixes_force_even_sprite_positions">Force Even Sprite Positions</string>
    <string name="fixes_force_even_sprite_positions_help">Forces even sprite/texture positions (UserHacks_ForceEvenSpritePosition).</string>
    <string name="fixes_palette_texture">Palette Texture</string>
    <string name="fixes_palette_texture_help">Draws palette textures at native res to fix colour issues when upscaling.</string>
    <string name="fixes_texture_offset_x">Texture Offset X</string>
    <string name="fixes_texture_offset_x_help">Horizontal texture-coordinate offset. 0 unless a game needs it.</string>
    <string name="fixes_texture_offset_y">Texture Offset Y</string>
    <string name="fixes_texture_offset_y_help">Vertical texture-coordinate offset. 0 unless a game needs it.</string>
    <string name="fixes_force_user_hacks">Force User Hacks</string>
    <string name="fixes_force_user_hacks_help">Force-enables the PCSX2 hardware-fix layer (UserHacks).</string>
    <string name="fixes_alpha_prite">Alpha Sprite</string>
    <string name="fixes_alpha_prite_help">Helps some sprite/alpha effects update correctly; can cost performance.</string>
    <string name="fixes_rt_sampling">RT Sampling</string>
    <string name="fixes_rt_sampling_help">Helps effects that sample from render targets; can alter or slow rendering.</string>
    <string name="fixes_clut_render">CLUT Render</string>
    <string name="fixes_clut_render_help">Palette handling hack for games with broken colours or CLUT effects.</string>
    <string name="fixes_sprite_bandwidth">Sprite Bandwidth</string>
    <string name="fixes_sprite_bandwidth_help">CPU sprite-render bandwidth limit. Useful only for specific sprite glitches.</string>
    <string name="fixes_sprite_cpu">Sprite CPU</string>
    <string name="fixes_sprite_cpu_help">Renders selected sprite work on CPU to fix difficult hardware-renderer issues.</string>
    <string name="fixes_cpu_clut">CPU CLUT</string>
    <string name="fixes_cpu_clut_help">Renders CLUTs on the CPU to fix palette/colour issues in some games.</string>
    <string name="fixes_depth_zfb">Depth ZFB</string>
    <string name="fixes_depth_zfb_help">Depth-buffer hack that can reduce z-fighting in some hardware-rendered games.</string>
    <string name="fixes_palette_conversion">Palette Conversion</string>
    <string name="fixes_palette_conversion_help">Does palette conversion on the GPU. Can help or hurt depending on the game.</string>
    <string name="fixes_fb_conversion">FB Conversion</string>
    <string name="fixes_fb_conversion_help">Converts framebuffer formats on the CPU to fix specific effects.</string>
    <string name="fixes_flush_rt_after_draw">Flush RT After Draw</string>
    <string name="fixes_flush_rt_after_draw_help">Flushes render targets back to memory when closing them.</string>
    <string name="fixes_preload_frame_data">Preload Frame Data</string>
    <string name="fixes_preload_frame_data_help">Uploads the previous frame\'s data before drawing. Fixes some effects.</string>
    <string name="fixes_texture_inside_rt">Texture Inside RT</string>
    <string name="fixes_texture_inside_rt_help">Estimates the used texture region. Helps games that read odd regions.</string>
    <string name="fixes_command_buffer">Command Buffer</string>
    <string name="fixes_command_buffer_help">Buffers draws before submitting. Can help a few games; diagnostic.</string>
    <string name="fixes_disable_depth_conversion">Disable Depth Conversion</string>
    <string name="fixes_disable_depth_conversion_help">Disables depth emulation. Faster but breaks many games — last resort.</string>
    <string name="fixes_disable_invalidation">Disable Invalidation</string>
    <string name="fixes_disable_invalidation_help">Disables partial texture-cache source invalidation.</string>
    <string name="fixes_skip_above">Skip Draw Start</string>
    <string name="fixes_skip_above_help">First draw call to skip (UserHacks_SkipDraw). 0 = off. Advanced.</string>
    <string name="fixes_skip_below">Skip Draw End</string>
    <string name="fixes_skip_below_help">Last draw call to skip. 0 = off. Advanced.</string>
    <string name="fixes_gpu_busy_wait">GPU Busy Wait</string>
    <string name="fixes_gpu_busy_wait_help">Busy-waits the GPU on readbacks to reduce stalls. Can raise power use.</string>
    <string name="fixes_cpu_busy_wait">CPU Busy Wait</string>
    <string name="fixes_cpu_busy_wait_help">Busy-waits the CPU on readbacks to reduce stalls. Can raise power use.</string>
    <string name="fixes_sw_auto_flush">SW Auto Flush</string>
    <string name="fixes_sw_auto_flush_help">Software-renderer auto-flush. On by default for correctness.</string>
    <string name="fixes_sw_mipmap">SW Mipmap</string>
    <string name="fixes_sw_mipmap_help">Software-renderer mipmapping. On by default.</string>
    <string name="fixes_sw_threads">SW Threads</string>
    <string name="fixes_sw_threads_help">Extra worker threads for the software renderer. 0 = single-threaded.</string>
    <string name="fixes_sw_tile_height">SW Tile Height</string>
    <string name="fixes_sw_tile_height_help">Software-renderer tile height per thread. Default 4. Restart the game to apply.</string>

